# OpenAI-compatible compiler provider. Ollama's OpenAI-compatible endpoint is the local default.
THREADSWARM_LLM_BASE_URL=http://localhost:11434/v1
THREADSWARM_LLM_MODEL=llama3.2
THREADSWARM_LLM_TIMEOUT=60

# Optional default for app-level worker sizing. Individual pools can still override this.
THREADSWARM_DEFAULT_WORKERS=
